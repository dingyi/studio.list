---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "studio.list",
  description = "A curated directory of exceptional design agencies.",
  image = "/og-default.svg",
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://studio.list");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2f2f2" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site ?? "https://studio.list")} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
