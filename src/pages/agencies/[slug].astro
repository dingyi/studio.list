---
import { ArrowUpRight, ExternalLink } from "lucide-react";
import PageHeader from "@/components/PageHeader";
import SiteFooter from "@/components/SiteFooter.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  formatLocations,
  getSimilarAgencies,
  publishedAgencies,
  type Agency,
} from "@/lib/catalog";

export function getStaticPaths() {
  const total = publishedAgencies.length;

  return publishedAgencies.map((agency, index) => ({
    params: { slug: agency.slug },
    props: { agency, position: index + 1, total },
  }));
}

interface Props {
  agency: Agency;
  position: number;
  total: number;
}

const { agency, position, total } = Astro.props;
const description = agency.description || `Discover ${agency.name}, an independent design agency listed on studio.list.`;
const location = formatLocations(agency);
const counterWidth = String(total).length;
const positionLabel = String(position).padStart(counterWidth, "0");
const totalLabel = String(total).padStart(counterWidth, "0");
const monogram = agency.name.trim().slice(0, 1).toUpperCase();
const similarAgencies = getSimilarAgencies(agency);
---

<BaseLayout title={`${agency.name} — studio.list`} description={description} image={agency.screenshot}>
  <PageHeader client:load />
  <main class="agency-detail">
    <div class="detail-utility">
      <a
        class="detail-close"
        href="/#directory"
        aria-label="Close agency detail"
        aria-keyshortcuts="Escape"
        data-detail-close
      >
        <span>Close</span>
        <kbd>Esc</kbd>
      </a>
      <div class="detail-logo">
        {agency.logo
          ? <img src={agency.logo} alt={`${agency.name} logo`} />
          : <span class="detail-logo__fallback" aria-hidden="true">{monogram}</span>}
      </div>
      <p class="detail-counter" aria-label={`Agency ${position} of ${total}`}>
        {positionLabel} / {totalLabel}
      </p>
    </div>

    <article class="detail-profile" aria-labelledby="agency-title">
      <figure class="detail-media">
        <img src={agency.screenshot} alt={`Homepage screenshot of ${agency.name}`} width="1440" height="900" />
      </figure>

      <h1 id="agency-title">{agency.name}</h1>

      <dl class="detail-facts">
        <div class="detail-fact detail-fact--about">
          <dt>About</dt>
          <dd>{description}</dd>
        </div>
        <div class="detail-fact">
          <dt>Location</dt>
          <dd>{location}</dd>
        </div>
        <div class="detail-fact">
          <dt>Website</dt>
          <dd>
            <a
              class="detail-website"
              href={agency.website}
              target="_blank"
              rel="noreferrer"
              aria-label={`Visit official website for ${agency.name}`}
            >
              <span>{agency.officialDomain}</span>
              <ArrowUpRight size={14} aria-hidden="true" />
            </a>
          </dd>
        </div>
      </dl>
    </article>

    <section class="similar-agencies" aria-labelledby="similar-agencies-title">
      <h2 id="similar-agencies-title">Explore similar agencies to {agency.name}</h2>
      <div class="similar-agencies__grid">
        {similarAgencies.map((similarAgency) => (
          <article class="agency-card agency-card--card">
            <a
              class="agency-card__main"
              href={`/agencies/${similarAgency.slug}/`}
              aria-label={`View ${similarAgency.name}`}
            >
              <div class="agency-card__media">
                <img
                  src={similarAgency.screenshot}
                  alt={`${similarAgency.name} website homepage`}
                  loading="lazy"
                  width="1440"
                  height="900"
                />
              </div>
              <div class="agency-card__body">
                <div>
                  <h3>{similarAgency.name}</h3>
                  <p class="agency-card__location">{formatLocations(similarAgency)}</p>
                </div>
              </div>
            </a>
            <a
              class="agency-card__external"
              href={similarAgency.website}
              target="_blank"
              rel="noreferrer"
              aria-label={`Open ${similarAgency.name} website in a new tab`}
            >
              <ExternalLink size={17} aria-hidden="true" />
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
  <SiteFooter />

  <script>
    const closeLink = document.querySelector<HTMLAnchorElement>("[data-detail-close]");

    function returnFromDetail() {
      let hasSameOriginReferrer = false;
      try {
        hasSameOriginReferrer = new URL(document.referrer).origin === window.location.origin;
      } catch {
        hasSameOriginReferrer = false;
      }

      if (hasSameOriginReferrer && window.history.length > 1) {
        window.history.back();
        return;
      }
      window.location.assign("/#directory");
    }

    closeLink?.addEventListener("click", (event) => {
      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
      event.preventDefault();
      returnFromDetail();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || event.defaultPrevented) return;
      if (document.querySelector('[role="dialog"]')) return;
      returnFromDetail();
    });
  </script>
</BaseLayout>
